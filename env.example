# Configuración de Variables de Entorno
# Copia este archivo como .env y completa los valores.

# Gemini API Key
# Debes obtener una clave de API desde Google AI Studio (https://aistudio.google.com/)
# Esta clave es necesaria para que el agente de IA pueda generar sugerencias de subtareas.
GEMINI_API_KEY=tu_clave_de_gemini_aqui
